generator client {
  provider        = "prisma-client-js"
  engineType      = "library"
  previewFeatures = ["relationJoins"]
  binaryTargets   = ["linux-musl", "native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
}

// ============================================
// better-auth models
// ============================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  username      String?   @unique
  emailVerified Boolean   @default(false)
  name          String
  image         String?
  role          String    @default("user") // "admin" | "user"
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions        Session[]
  accounts        Account[]
  assignedRouters RouterAssignment[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  userId    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("verifications")
}

// ============================================
// RBAC — Router Assignment
// ============================================

model RouterAssignment {
  id        String   @id @default(cuid())
  userId    String
  routerId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  router Router @relation(fields: [routerId], references: [id], onDelete: Cascade)

  @@unique([userId, routerId])
  @@map("router_assignments")
}

// ============================================
// Application models
// ============================================

model Router {
  id           String    @id @default(cuid())
  name         String    @unique
  ipAddress    String
  port         Int       @default(443)
  useSSL       Boolean   @default(true)
  username     String
  password     String    // Encrypted AES-256-GCM
  isActive     Boolean   @default(true)
  lastPollAt   DateTime?
  status       String    @default("unknown") // online, offline, error
  errorMessage String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  queues      Queue[]
  assignments RouterAssignment[]

  @@map("routers")
}

model Queue {
  id         String   @id @default(cuid())
  routerId   String
  name       String
  target     String
  maxLimit   String   @default("0/0")
  limitAt    String   @default("0/0")
  parent     String   @default("")
  isDeleted  Boolean  @default(false)
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  router    Router         @relation(fields: [routerId], references: [id], onDelete: Cascade)
  histories QueueHistory[]

  @@unique([routerId, name])
  @@index([routerId])
  @@index([isDeleted])
  @@map("queues")
}

model QueueHistory {
  id            String   @id @default(cuid())
  queueId       String
  routerId      String
  uploadBytes   BigInt
  downloadBytes BigInt
  totalBytes    BigInt
  rateUpload    String?
  rateDownload  String?
  packetRate    String?
  timestamp     DateTime @default(now())

  queue Queue @relation(fields: [queueId], references: [id], onDelete: Cascade)

  @@index([timestamp])
  @@index([queueId, timestamp])
  @@map("queue_histories")
}

// ============================================
// WireGuard VPN
// ============================================

model WireguardConfig {
  id         String   @id @default("default")
  privateKey String
  publicKey  String
  address    String   @default("10.0.0.1/24")
  port       Int      @default(51820)
  mtu        Int      @default(1420)
  dns        String   @default("10.0.0.1")
  nextIp     Int      @default(2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("wireguard_config")
}

model WireguardPeer {
  id                   String   @id @default(cuid())
  name                 String
  enabled              Boolean  @default(true)
  privateKey           String
  publicKey            String
  presharedKey         String?
  allowedIPs           String
  address              String
  endpoint             String?
  dns                  String?
  persistentKeepalive  Int      @default(25)
  comment              String?
  transferRx           BigInt   @default(0)
  transferTx           BigInt   @default(0)
  latestHandshakeAt    DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@map("wireguard_peers")
}

// ============================================
// Hotspot — Profile Metadata (Mikhmon-style)
// ============================================

model HotspotProfile {
  id             String   @id @default(cuid())
  name           String
  routerId       String
  sharedUsers    Int      @default(1)
  rateLimit      String?
  addressPool    String?
  macCookie      Boolean  @default(false)
  server         String   @default("all")
  expiredMode    String   @default("remove") // remove | notice | remove_record | notice_record
  price          Int      @default(0)
  sellPrice      Int      @default(0)
  lockUser       Boolean  @default(false)
  validity       String   @default("")
  onLoginScript  String?
  onLogoutScript String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([routerId, name])
  @@map("hotspot_profiles")
}

model HotspotTransaction {
  id           String    @id @default(cuid())
  routerId     String
  username     String
  profileName  String
  price        Int       @default(0)
  batchComment String?
  soldAt       DateTime  @default(now())
  recordedBy   String?   // auto | generate | scheduler | manual
  expiresAt    DateTime?
  status       String    @default("active") // active | expired | removed

  @@map("hotspot_transactions")
}

model HotspotRouterScript {
  id        String   @id @default(cuid())
  routerId  String
  type      String   // on-login | on-logout
  name      String
  content   String
  deployed  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([routerId, type, name])
  @@map("hotspot_router_scripts")
}

model HotspotActivityLog {
  id          String   @id @default(cuid())
  routerId    String
  username    String
  ipAddress   String?
  macAddress  String?
  profileName String?
  validity    String?
  type        String   // login | logout
  message     String?
  loggedAt    DateTime @default(now())

  @@index([routerId, loggedAt])
  @@index([username])
  @@map("hotspot_activity_logs")
}
